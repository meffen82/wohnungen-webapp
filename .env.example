# Öffentliche URL der App (ohne trailing slash)
APP_URL=https://example.com

# URL-Token — einzige Authentifizierung
# Generieren: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
WOHNUNGEN_SECRET=<dein-token>

# Pfad zur Hermes-Datei (Host-Pfad, wird read-only gemountet)
HERMES_DATA_PATH=/pfad/zu/hermes/data
